{
    "name": "legend-list-web-example",
    "private": true,
    "version": "0.0.0",
    "type": "module",
    "scripts": {
        "dev": "VITE_LEGEND_LIST_MODE=examples vite",
        "dev:fixtures": "VITE_LEGEND_LIST_MODE=fixtures vite",
        "devs": "VITE_LEGEND_LIST_MODE=examples vite --mode https --port 5174",
