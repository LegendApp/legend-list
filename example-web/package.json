        "react-window": "^2.2.5",
        "virtua": "^0.41.5"
    },
    "devDependencies": {
        "@tailwindcss/vite": "^4.1.14",
        "@types/react": "19.2.0",
        "@types/react-dom": "19.2.0",
        "@vitejs/plugin-react": "^5.0.4",
        "tailwindcss": "^4.0.0",
        "typescript": "^5.0.2",
        "vite": "^7.1.11",
        "vite-plugin-mkcert": "^1.17.9"
    }
