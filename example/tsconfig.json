{
    "compilerOptions": {
        "paths": {
            "@/*": [
                "../src/*"
            ],
            "@/components/*": [
                "../src/components/*",
            ],
            "@/core/*": [
                "../src/core/*"
            ],
            "@/hooks/*": [
                "../src/hooks/*"
            ],
            "@/integrations/*": [
                "../src/integrations/*"
            ],
            "@/state/*": [
                "../src/state/*"
            ],
            "@/utils/*": [
                "../src/utils/*"
            ],
            "@legendapp/list": [
                "../src/index"
            ],
            "@legendapp/list/react-native": [
                "../src/react-native"
            ],
            "@legendapp/list/keyboard": [
                "../src/integrations/keyboard"
            ],
            "@legendapp/list/keyboard-test": [
                "../src/integrations/keyboard-test"
            ],
            "@legendapp/list/reanimated": [
                "../src/integrations/reanimated"
            ],
            "~/*": [
                "./*"
            ]
        },
        "strict": true,
        "types": [
            "react",
            "react-native",
            "jest",
            "node"
        ]
    },
    "extends": "expo/tsconfig.base",
    "include": [
        "**/*.ts",
        "**/*.tsx",
        ".expo/types/**/*.ts",
        "expo-env.d.ts"
    ]
}