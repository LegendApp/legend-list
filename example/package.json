{
    "name": "list-test",
    "license": "MIT",
    "main": "expo-router/entry",
    "version": "1.0.0",
    "scripts": {
        "start": "EXPO_PUBLIC_LEGEND_LIST_MODE=examples expo start",
        "start:fixtures": "EXPO_PUBLIC_LEGEND_LIST_MODE=fixtures expo start",
        "android": "EXPO_PUBLIC_LEGEND_LIST_MODE=examples expo run:android",
        "android:fixtures": "EXPO_PUBLIC_LEGEND_LIST_MODE=fixtures expo run:android",
        "android:release": "RELEASE=TRUE expo run:android --variant release",
        "ios": "EXPO_PUBLIC_LEGEND_LIST_MODE=examples expo run:ios",
        "ios:fixtures": "EXPO_PUBLIC_LEGEND_LIST_MODE=fixtures expo run:ios",
        "web": "EXPO_PUBLIC_LEGEND_LIST_MODE=examples expo start --web",
        "web:fixtures": "EXPO_PUBLIC_LEGEND_LIST_MODE=fixtures expo start --web",
        "test": "jest --watchAll",
        "lint": "expo lint",
        "prebuild:clean": "rm -rf ios android && npx expo prebuild --clean && npx expo prebuild"
    },
    "jest": {
        "preset": "jest-expo"
    },
    "dependencies": {
        "@expo/vector-icons": "^15.0.3",
        "@legendapp/motion": "^2.4.0",
        "@legendapp/state": "^3.0.0-beta.19",
        "@shopify/flash-list": "2.0.2",
        "babel-plugin-react-compiler": "^19.1.0-rc.2",
        "countries-list": "^3.1.1",
        "expo": "~54.0.33",
        "expo-atlas": "^0.4.0",
        "expo-blur": "~15.0.8",
        "expo-constants": "~18.0.13",
        "expo-dev-client": "~6.0.20",
        "expo-font": "~14.0.11",
        "expo-haptics": "~15.0.8",
        "expo-linear-gradient": "~15.0.8",
        "expo-linking": "~8.0.11",
        "expo-router": "~6.0.23",
        "expo-build-properties": "~1.0.10",
        "expo-splash-screen": "~31.0.13",
        "expo-status-bar": "~3.0.9",
        "expo-symbols": "~1.0.8",
        "expo-system-ui": "~6.0.9",
        "expo-web-browser": "~15.0.10",
        "react": "19.1.0",
        "react-compiler-runtime": "^19.1.0-rc.2",
        "react-dom": "19.1.0",
        "react-native": "0.81.5",
        "react-native-gesture-handler": "~2.28.0",
        "react-native-keyboard-controller": "^1.21.4",
        "react-native-reanimated": "4.3.0",
        "react-native-redash": "^18.1.3",
        "react-native-safe-area-context": "~5.6.0",
        "react-native-screens": "~4.16.0",
        "react-native-web": "^0.21.0",
        "react-native-webview": "13.15.0",
        "react-native-worklets": "0.8.1",
        "react-native-worklets-core": "1.6.3"
    },
    "devDependencies": {
        "@babel/core": "^7.27.4",
        "@react-native-community/cli": "latest",
        "@types/expo__vector-icons": "^10.0.2",
        "@types/jest": "^29.5.14",
        "@types/react": "~19.1.10",
        "@types/react-test-renderer": "^19.0.0",
        "jest": "~29.7.0",
        "jest-expo": "~54.0.17",
        "react-test-renderer": "19.0.0",
        "typescript": "~5.9.2"
    },
    "overrides": {
        "@react-navigation/bottom-tabs": "7.4.0",
        "@react-navigation/native": "7.1.11"
    },
    "reanimated": {
        "staticFeatureFlags": {
            "DISABLE_COMMIT_PAUSING_MECHANISM": true,
            "ANDROID_SYNCHRONOUSLY_UPDATE_UI_PROPS": true,
            "IOS_SYNCHRONOUSLY_UPDATE_UI_PROPS": true,
            "FORCE_REACT_RENDER_FOR_SETTLED_ANIMATIONS": true,
            "USE_COMMIT_HOOK_ONLY_FOR_REACT_COMMITS": true
        }
    },
    "private": true
}
